---
const currentYear = new Date().getFullYear();
---
<footer>
  <div class="footer-inner">
    <span>© {currentYear} straypackets.com</span>
    <div class="footer-links">
      <a href="/rss.xml">RSS</a>
      <a href="https://github.com/dedgar1" target="_blank">GitHub</a>
    </div>
  </div>
</footer>

<style>
  footer {
    padding: 2rem;
    border-top: 1px solid rgb(var(--gray-light));
    margin-top: 4rem;
  }
  .footer-inner {
    max-width: 720px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.85rem;
    color: rgb(var(--gray));
  }
  .footer-links {
    display: flex;
    gap: 1.5rem;
  }
  .footer-links a {
    color: rgb(var(--gray));
    text-decoration: none;
  }
  .footer-links a:hover {
    color: var(--accent);
  }
</style>