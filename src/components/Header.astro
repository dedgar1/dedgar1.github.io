---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
  <nav>
    <div class="brand">
      <a href="/">straypackets.com</a>
      <span class="tagline">Stray thoughts, tech musings, and everything in between.</span>
    </div>
    <div class="nav-links">
      <a href="/">Home</a>
      <a href="/blog">Blog</a>
      <a href="/about">About Me</a>
    </div>
  </nav>
</header>

<style>
  header {
    padding: 1.5rem 2rem;
    border-bottom: 1px solid rgb(var(--gray-light));
  }
  nav {
    max-width: 720px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .brand a {
    font-size: 1.2rem;
    font-weight: 600;
    text-decoration: none;
    color: rgb(var(--gray-dark));
  }
  .tagline {
    display: block;
    font-size: 0.75rem;
    color: rgb(var(--gray-dark));
    margin-top: 2px;
  }
  .nav-links {
    display: flex;
    gap: 1.5rem;
  }
  .nav-links a {
    text-decoration: none;
    color: rgb(var(--gray));
    font-size: 0.95rem;
  }
  .nav-links a:hover {
    color: var(--accent);
  }
</style>